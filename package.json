{
  "name": "exh1b1t",
  "version": "1.0.0",
  "description": "Create a free photo portfolio hosted on GitHub Pages",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.0",
    "handlebars": "^4.7.8",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.exh1b1t.app",
    "productName": "EXH1B1T",
    "mac": {
      "category": "public.app-category.photography",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "publish": {
      "provider": "github",
      "owner": "YOUR_GITHUB_USERNAME",
      "repo": "exh1b1t"
    }
  }
}
